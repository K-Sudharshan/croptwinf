# Server Configuration
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=croptwin
DB_USER=postgres
DB_PASSWORD=password
DATABASE_URL=postgresql://postgres:password@localhost:5432/croptwin

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=7d

# AI/ML Services (Optional)
YOLO_API_URL=http://localhost:5000
TENSORFLOW_API_URL=http://localhost:5001
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_API_KEY=

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@croptwin.com
